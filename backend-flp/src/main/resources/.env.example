# =============================================
# Spring Boot — Aplicación
# =============================================
APP_NAME=backend

# PostgreSQL — Base de datos
DB_URL=jdbc:postgresql://localhost:5432/flores_eternas_lp
DB_USERNAME=postgres
DB_PASSWORD=tu_contrasena
DDL_AUTO=update

# JWT — Clave secreta (mínimo 64 caracteres para HMAC-SHA)
JWT_SECRET=tu_clave_secreta_jwt_minimo_64_caracteres

# =============================================
# PayU — Web Checkout (Tarjeta de crédito / débito)
# =============================================
# Obtén estos valores desde tu cuenta de PayU
PAYU_MERCHANT_ID=tu_merchant_id
PAYU_API_KEY=tu_api_key
PAYU_ACCOUNT_ID=tu_account_id
# URL de sandbox para pruebas, cambiar a producción cuando esté listo
PAYU_URL=https://sandbox.checkout.payulatam.com/ppp-web-gateway-payu/

# =============================================
# Mail — SMTP (para notificaciones al cliente)
# =============================================
# Ejemplo con Gmail: requiere contraseña de aplicación (no la contraseña normal)
# Cómo crearla: https://myaccount.google.com/apppasswords
MAIL_FROM=tu_correo@gmail.com
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=tu_correo@gmail.com
spring.mail.password=tu_contraseña_de_aplicacion
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true