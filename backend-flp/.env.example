# =============================================
# Flores Eternas LP — Backend (Spring Boot)
# =============================================
# Copia este archivo como ".env" en src/main/resources/ y completa los valores.
# springboot4-dotenv carga automáticamente el .env desde el classpath.
#
# Si necesitas cambiar la configuración para tu entorno local
# (puerto de PostgreSQL, usuario, contraseña, nombre de BD),
# solo modifica el archivo .env en src/main/resources/.env

# Nombre de la aplicación
APP_NAME=backend

# PostgreSQL — URL de conexión
DB_URL=jdbc:postgresql://localhost:5432/flores_eternas_lp

# PostgreSQL — Usuario
DB_USERNAME=postgres

# PostgreSQL — Contraseña
DB_PASSWORD=tu_contraseña_aqui

# Hibernate DDL auto (update | validate | create | create-drop | none)
DDL_AUTO=update
