# =============================================
# Flores Eternas LP — Backend (Spring Boot)
# =============================================
# Copia este archivo como ".env" y completa los valores.
# Las variables son leídas desde la terminal/IDE (NO automáticamente por Spring Boot desde .env).
# En IntelliJ IDEA puedes usar el plugin "EnvFile" o setearlas en Run Configuration.
# También puedes exportarlas en tu shell:
#   export DB_URL=jdbc:postgresql://localhost:5432/flores_eternas_lp

# Nombre de la aplicación
APP_NAME=backend

# PostgreSQL — URL de conexión
DB_URL=jdbc:postgresql://localhost:5432/flores_eternas_lp

# PostgreSQL — Usuario
DB_USERNAME=postgres

# PostgreSQL — Contraseña
DB_PASSWORD=tu_contraseña_aqui

# Hibernate DDL auto (update | validate | create | create-drop | none)
DDL_AUTO=update
